# Copy this file to backend/.env for local development overrides.
# The backend loads .env from the backend/ working directory.

WIFRY_HOST=0.0.0.0
WIFRY_PORT=8080
WIFRY_DEBUG=true
WIFRY_MOCK_MODE=true

# Uncomment for explicit local storage overrides.
# WIFRY_DATA_DIR=/tmp/wifry-data
# WIFRY_CAPTURES_DIR=/tmp/wifry-data/captures

# Uncomment on real hardware if interface auto-detection is not correct.
# WIFRY_AP_INTERFACE=wlan0
# WIFRY_UPSTREAM_INTERFACE=eth0

# Default WiFi AP values for a fresh appliance.
# WIFRY_AP_SSID=WiFry
# WIFRY_AP_PASSWORD=wifry1234
# WIFRY_AP_CHANNEL=6
# WIFRY_AP_BAND=2.4GHz

# AI analysis provider configuration.
# WIFRY_AI_PROVIDER=anthropic
WIFRY_ANTHROPIC_API_KEY=
WIFRY_OPENAI_API_KEY=

# DNS overrides.
# WIFRY_DNS_ENABLED=true
# WIFRY_COREDNS_BINARY=/usr/local/bin/coredns
