{
  "name": "Slow DNS",
  "description": "Slow DNS responses causing delayed channel changes and app loading",
  "builtin": true,
  "category": "dns",
  "tags": ["dns", "slow", "latency"],
  "config": {},
  "wifi_config": null,
  "dns_config": {
    "enabled": true,
    "listen_port": 5053,
    "log_queries": true,
    "upstream": {
      "provider": "cloudflare",
      "custom_servers": [],
      "protocol": "plain"
    },
    "impairments": {
      "delay_ms": 500,
      "failure_rate_pct": 0,
      "nxdomain_domains": [],
      "servfail_rate_pct": 0,
      "ttl_override": 5
    },
    "overrides": []
  }
}
