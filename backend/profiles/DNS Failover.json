{
  "name": "DNS Failover",
  "description": "Primary DNS resolver failing, secondary responding — tests DNS failover and retry behavior on STBs",
  "builtin": true,
  "category": "dns",
  "tags": ["dns", "failover", "multi-resolver", "resilience", "retry"],
  "config": {},
  "wifi_config": null,
  "dns_config": {
    "enabled": true,
    "listen_port": 5053,
    "log_queries": true,
    "upstream": {
      "provider": "multi",
      "custom_servers": [],
      "protocol": "plain",
      "resolvers": [
        {"address": "192.0.2.1", "label": "Primary (FAILED)", "healthy": false, "delay_ms": 0},
        {"address": "1.1.1.1", "label": "Secondary (Cloudflare)", "healthy": true, "delay_ms": 0}
      ]
    },
    "impairments": {
      "delay_ms": 0,
      "failure_rate_pct": 0,
      "nxdomain_domains": [],
      "servfail_rate_pct": 0,
      "ttl_override": 0
    },
    "overrides": []
  }
}
