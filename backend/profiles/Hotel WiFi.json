{
  "name": "Hotel WiFi",
  "description": "Simulates typical hotel WiFi — slow, congested, with captive portal DNS behavior",
  "builtin": true,
  "category": "combined",
  "tags": ["wifi", "dns", "hotel", "real-world", "captive-portal", "congested"],
  "config": {
    "delay": {
      "ms": 80,
      "jitter_ms": 40,
      "correlation_pct": 30
    },
    "loss": {
      "pct": 1.5,
      "correlation_pct": 30
    },
    "rate": {
      "kbit": 5000,
      "burst": "32kbit"
    }
  },
  "wifi_config": {
    "channel_interference": {
      "enabled": true,
      "beacon_interval_ms": 200,
      "rts_threshold": 1000
    },
    "tx_power": {
      "enabled": false,
      "power_dbm": 20
    },
    "band_switch": {
      "enabled": false,
      "target_band": "2.4GHz",
      "target_channel": 0,
      "bounce_enabled": false,
      "bounce_interval_secs": 60,
      "bounce_band_a": "2.4GHz",
      "bounce_channel_a": 6,
      "bounce_band_b": "5GHz",
      "bounce_channel_b": 36,
      "channel_hop_enabled": false,
      "channel_hop_interval_secs": 30,
      "channel_hop_list": "1,6,11"
    },
    "deauth": {
      "enabled": false,
      "target_mac": "",
      "reason_code": 3
    },
    "dhcp_disruption": {
      "enabled": false,
      "mode": "delay",
      "delay_secs": 30
    },
    "broadcast_storm": {
      "enabled": false,
      "packets_per_sec": 100,
      "packet_size_bytes": 512
    },
    "rate_limit": {
      "enabled": true,
      "legacy_rate_mbps": 24,
      "ht_mcs": 5,
      "vht_mcs": -1
    },
    "periodic_disconnect": {
      "enabled": false,
      "interval_secs": 300,
      "disconnect_duration_secs": 5,
      "target_mac": ""
    }
  },
  "dns_config": {
    "enabled": true,
    "listen_port": 5053,
    "log_queries": true,
    "upstream": {
      "provider": "cloudflare",
      "custom_servers": [],
      "protocol": "plain"
    },
    "impairments": {
      "delay_ms": 200,
      "failure_rate_pct": 3,
      "nxdomain_domains": [],
      "servfail_rate_pct": 2,
      "ttl_override": 10
    },
    "overrides": []
  }
}
