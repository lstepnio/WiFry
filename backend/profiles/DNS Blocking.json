{
  "name": "DNS Blocking",
  "description": "Simulates ISP DNS blocking — specific CDN domains return NXDOMAIN",
  "builtin": true,
  "category": "dns",
  "tags": ["dns", "blocking", "nxdomain", "censorship"],
  "config": {},
  "wifi_config": null,
  "dns_config": {
    "enabled": true,
    "listen_port": 5053,
    "log_queries": true,
    "upstream": {
      "provider": "cloudflare",
      "custom_servers": [],
      "protocol": "plain"
    },
    "impairments": {
      "delay_ms": 50,
      "failure_rate_pct": 0,
      "nxdomain_domains": [
        "*.cdn.example.com",
        "*.streaming.example.com"
      ],
      "servfail_rate_pct": 0,
      "ttl_override": 0
    },
    "overrides": []
  }
}
