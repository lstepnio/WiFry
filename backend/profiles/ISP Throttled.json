{
  "name": "ISP Throttled",
  "description": "ISP throttling scenario — bandwidth limited with DNS manipulation and high latency",
  "builtin": true,
  "category": "combined",
  "tags": ["network", "dns", "isp", "throttled", "real-world", "bandwidth"],
  "config": {
    "delay": {
      "ms": 40,
      "jitter_ms": 15,
      "correlation_pct": 25
    },
    "loss": {
      "pct": 0.3,
      "correlation_pct": 20
    },
    "rate": {
      "kbit": 8000,
      "burst": "32kbit"
    }
  },
  "wifi_config": null,
  "dns_config": {
    "enabled": true,
    "listen_port": 5053,
    "log_queries": true,
    "upstream": {
      "provider": "google",
      "custom_servers": [],
      "protocol": "plain"
    },
    "impairments": {
      "delay_ms": 150,
      "failure_rate_pct": 2,
      "nxdomain_domains": [],
      "servfail_rate_pct": 1,
      "ttl_override": 30
    },
    "overrides": []
  }
}
