{
  "name": "Flaky WiFi",
  "description": "Intermittent WiFi with periodic disconnects and DHCP issues - common real-world complaint",
  "builtin": true,
  "category": "combined",
  "tags": ["wifi", "flaky", "disconnect", "real-world", "intermittent"],
  "config": {
    "delay": { "ms": 10, "jitter_ms": 20, "correlation_pct": 50 },
    "loss": { "pct": 0.3, "correlation_pct": 40 }
  },
  "wifi_config": {
    "periodic_disconnect": { "enabled": true, "interval_secs": 180, "disconnect_duration_secs": 3, "target_mac": "" },
    "dhcp_disruption": { "enabled": true, "mode": "delay", "delay_secs": 10 },
    "channel_interference": { "enabled": false, "beacon_interval_ms": 100, "rts_threshold": 2347 },
    "tx_power": { "enabled": false, "power_dbm": 20 },
    "rate_limit": { "enabled": false, "legacy_rate_mbps": 54, "ht_mcs": -1, "vht_mcs": -1 },
    "band_switch": { "enabled": false, "target_band": "2.4GHz", "target_channel": 0 },
    "deauth": { "enabled": false, "target_mac": "", "reason_code": 3 },
    "broadcast_storm": { "enabled": false, "packets_per_sec": 100, "packet_size_bytes": 512 }
  }
}
