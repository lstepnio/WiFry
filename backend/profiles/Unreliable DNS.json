{
  "name": "Unreliable DNS",
  "description": "DNS with 10% failure rate and 5% SERVFAIL — tests DNS retry and fallback logic",
  "builtin": true,
  "category": "dns",
  "tags": ["dns", "unreliable", "failure", "retry"],
  "config": {},
  "wifi_config": null,
  "dns_config": {
    "enabled": true,
    "listen_port": 5053,
    "log_queries": true,
    "upstream": {
      "provider": "google",
      "custom_servers": [],
      "protocol": "plain"
    },
    "impairments": {
      "delay_ms": 100,
      "failure_rate_pct": 10,
      "nxdomain_domains": [],
      "servfail_rate_pct": 5,
      "ttl_override": 0
    },
    "overrides": []
  }
}
