# WiFry sudoers rules — allow the wifry user to run network management commands
# Install to: /etc/sudoers.d/wifry

# Traffic control
wifry ALL=(ALL) NOPASSWD: /sbin/tc
wifry ALL=(ALL) NOPASSWD: /usr/sbin/tc

# Network interfaces
wifry ALL=(ALL) NOPASSWD: /sbin/ip
wifry ALL=(ALL) NOPASSWD: /usr/sbin/ip

# Firewall
wifry ALL=(ALL) NOPASSWD: /sbin/iptables
wifry ALL=(ALL) NOPASSWD: /usr/sbin/iptables

# Packet capture (dumpcap for capture, tshark for post-processing, mergecap for segment merge)
wifry ALL=(ALL) NOPASSWD: /usr/bin/dumpcap
wifry ALL=(ALL) NOPASSWD: /usr/bin/tshark
wifry ALL=(ALL) NOPASSWD: /usr/bin/mergecap
wifry ALL=(ALL) NOPASSWD: /usr/bin/capinfos
wifry ALL=(ALL) NOPASSWD: /usr/bin/nice
wifry ALL=(ALL) NOPASSWD: /usr/bin/ionice
wifry ALL=(ALL) NOPASSWD: /usr/bin/cat

# WiFi AP management
wifry ALL=(ALL) NOPASSWD: /usr/sbin/hostapd_cli

# WiFi radio control
wifry ALL=(ALL) NOPASSWD: /usr/sbin/rfkill

# WiFi scanning
wifry ALL=(ALL) NOPASSWD: /sbin/iw
wifry ALL=(ALL) NOPASSWD: /usr/sbin/iw
wifry ALL=(ALL) NOPASSWD: /sbin/iwlist
wifry ALL=(ALL) NOPASSWD: /usr/sbin/iwlist

# Broadcast storm injection
wifry ALL=(ALL) NOPASSWD: /usr/sbin/hping3

# Service management
wifry ALL=(ALL) NOPASSWD: /bin/systemctl restart hostapd
wifry ALL=(ALL) NOPASSWD: /bin/systemctl restart dnsmasq
wifry ALL=(ALL) NOPASSWD: /bin/systemctl restart dhcpcd
wifry ALL=(ALL) NOPASSWD: /bin/systemctl restart wifry-backend
wifry ALL=(ALL) NOPASSWD: /bin/systemctl stop hostapd
wifry ALL=(ALL) NOPASSWD: /bin/systemctl stop dnsmasq
wifry ALL=(ALL) NOPASSWD: /bin/systemctl stop wifry-backend
wifry ALL=(ALL) NOPASSWD: /bin/systemctl start hostapd
wifry ALL=(ALL) NOPASSWD: /bin/systemctl start dnsmasq
wifry ALL=(ALL) NOPASSWD: /bin/systemctl start wifry-backend
wifry ALL=(ALL) NOPASSWD: /bin/systemctl reload dnsmasq
wifry ALL=(ALL) NOPASSWD: /bin/systemctl is-active hostapd
wifry ALL=(ALL) NOPASSWD: /bin/systemctl is-active dnsmasq
wifry ALL=(ALL) NOPASSWD: /bin/systemctl is-active wifry-backend
wifry ALL=(ALL) NOPASSWD: /bin/systemctl status *
wifry ALL=(ALL) NOPASSWD: /bin/systemctl reboot
wifry ALL=(ALL) NOPASSWD: /usr/bin/journalctl
wifry ALL=(ALL) NOPASSWD: /usr/bin/tail
wifry ALL=(ALL) NOPASSWD: /bin/chown
wifry ALL=(ALL) NOPASSWD: /bin/chmod

# IP forwarding
wifry ALL=(ALL) NOPASSWD: /sbin/sysctl -w net.ipv4.ip_forward=1

# VPN / Teleport
wifry ALL=(ALL) NOPASSWD: /usr/bin/wg-quick
wifry ALL=(ALL) NOPASSWD: /usr/sbin/openvpn
wifry ALL=(ALL) NOPASSWD: /usr/sbin/swanctl
wifry ALL=(ALL) NOPASSWD: /bin/killall openvpn

# CoreDNS
wifry ALL=(ALL) NOPASSWD: /usr/local/bin/coredns

# Config file writes via tee
wifry ALL=(ALL) NOPASSWD: /usr/bin/tee /etc/hostapd/hostapd.conf
wifry ALL=(ALL) NOPASSWD: /usr/bin/tee /etc/dnsmasq.d/wifry.conf
wifry ALL=(ALL) NOPASSWD: /usr/bin/tee /etc/dnsmasq.d/wifry-dns.conf
wifry ALL=(ALL) NOPASSWD: /usr/bin/tee /etc/dnsmasq.d/wifry-impairment.conf
wifry ALL=(ALL) NOPASSWD: /usr/bin/tee /etc/wireguard/*.conf

# Directory creation for config paths
wifry ALL=(ALL) NOPASSWD: /bin/mkdir -p /etc/hostapd
wifry ALL=(ALL) NOPASSWD: /bin/mkdir -p /etc/dnsmasq.d
wifry ALL=(ALL) NOPASSWD: /bin/mkdir -p /etc/wireguard

# File permissions for config writes
wifry ALL=(ALL) NOPASSWD: /bin/chmod 600 /etc/wireguard/*
wifry ALL=(ALL) NOPASSWD: /bin/chmod 600 /var/lib/wifry/teleport/*
wifry ALL=(ALL) NOPASSWD: /bin/cp * /etc/swanctl/conf.d/*
wifry ALL=(ALL) NOPASSWD: /bin/rm -f /etc/swanctl/conf.d/wifry-*
wifry ALL=(ALL) NOPASSWD: /bin/rm -f /etc/dnsmasq.d/wifry-*
